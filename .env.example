# Gemini API Config
GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL database connection URL
DATABASE_URL=postgresql://username:password@localhost:2004/database_name

# Toggle between simulated hybrid reranker and true cross-encoder model
USE_CROSS_ENCODER=false

# Enable BM25 + vector hybrid retrieval (rank_bm25 library required)
# When true, retrieval blends vector cosine score with BM25 keyword score
USE_HYBRID_SEARCH=false

# Enable LLM-powered query rewriting/expansion before retrieval
# When true, Gemini rewrites the query to be more descriptive for better recall
USE_QUERY_REWRITING=false
